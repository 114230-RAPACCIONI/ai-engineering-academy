generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  experience   String   @default("beginner") // beginner | experienced
  objectives   String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  journeys      LearningJourney[]
  conversations Conversation[]
  decisions     DecisionLogEntry[]
  projects      PracticeProject[]
}

model LearningPath {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  chapter     Int
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  modules  Module[]
  journeys LearningJourney[]
}

model Module {
  id              String @id @default(cuid())
  pathId          String
  slug            String
  title           String
  summary         String
  goal            String
  context         String
  expectedOutcome String
  body            String @default("")
  order           Int    @default(0)

  path     LearningPath       @relation(fields: [pathId], references: [id], onDelete: Cascade)
  progress ModuleProgress[]
  concepts KnowledgeConcept[]

  @@unique([pathId, slug])
}

model KnowledgeConcept {
  id           String  @id @default(cuid())
  slug         String  @unique
  title        String
  summary      String
  explanation  String
  example      String
  practicalUse String
  relatedSlugs String  @default("") // comma-separated slugs
  moduleId     String?
  order        Int     @default(0)

  module Module? @relation(fields: [moduleId], references: [id], onDelete: SetNull)
}

model LearningJourney {
  id              String   @id @default(cuid())
  userId          String
  pathId          String
  status          String   @default("active") // active | completed
  currentModuleId String?
  startedAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  path     LearningPath     @relation(fields: [pathId], references: [id], onDelete: Cascade)
  progress ModuleProgress[]

  @@unique([userId, pathId])
}

model ModuleProgress {
  id          String    @id @default(cuid())
  journeyId   String
  moduleId    String
  status      String    @default("not_started") // not_started | in_progress | completed
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  journey LearningJourney @relation(fields: [journeyId], references: [id], onDelete: Cascade)
  module  Module          @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([journeyId, moduleId])
}

model Conversation {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("Sesión con el Mentor")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String // user | assistant | system
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model DecisionLogEntry {
  id        String   @id @default(cuid())
  userId    String
  decision  String
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PracticeProject {
  id               String   @id @default(cuid())
  userId           String
  title            String
  domain           String   @default("")
  problemStatement String   @default("")
  scopeIn          String   @default("")
  scopeOut         String   @default("")
  nonGoals         String   @default("")
  successCriteria  String   @default("")
  status           String   @default("planning") // planning | active | done
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
